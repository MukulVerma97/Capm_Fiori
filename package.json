{
  "name": "CAPProj",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "cds-plugin-ui5": "^0.13.0",
    "eslint": "^8.57.1"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-capfiori": "cds watch --open com.list.fiori.capfiori/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-fioricap": "cds watch --open com.app.listreport.fioricap/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-ordermgmtui": "cds watch --open ordermgmtui/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-ordermgmt": "cds watch --open com.order.managment.ordermgmt/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/capfiori",
    "app/fioricap",
    "app/ordermgmtui",
    "app/ordermgmt"
  ],
  "cds": {}
}
